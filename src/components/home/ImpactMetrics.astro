---
import { home } from "@/content/home";
import SectionHeading from "@/components/SectionHeading.astro";

const { impact } = home;
---

<section id="impact" class="bg-cream-50 py-24 md:py-32">
  <div class="container-page">
    <SectionHeading eyebrow={impact.eyebrow} heading={impact.heading} />

    <img
      src="/images/home/solution.png"
      alt="The same farmer now standing confidently with a smartphone, surrounded by thriving crops and a connected network of weather, soil, and plant-health icons — illustrating life with AgroVision supporting every decision."
      loading="lazy"
      class="mx-auto mt-14 block w-full max-w-4xl rounded-3xl"
    />

    <div class="mt-12 grid gap-12 md:grid-cols-3 md:gap-10">
      {impact.items.map((item, i) => (
        <div class="group relative">
          {i > 0 && (
            <span
              class="hidden md:block absolute -left-5 top-2 h-24 w-px bg-ink-300/40"
              aria-hidden="true"
            ></span>
          )}
          <span class="block font-display text-5xl md:text-6xl font-medium text-forest-700/30 leading-none">
            {item.id}
          </span>
          <h3 class="mt-5 text-xl md:text-2xl font-medium text-ink-900">
            {item.title}
          </h3>
          <p class="mt-3 text-base leading-relaxed text-ink-500">
            {item.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
