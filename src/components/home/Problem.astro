---
import { home } from "@/content/home";
import SectionHeading from "@/components/SectionHeading.astro";

const { problem } = home;
---

<section id="problem" class="bg-cream-50 py-24 md:py-32">
  <div class="container-page">
    <SectionHeading
      eyebrow={problem.eyebrow}
      heading={problem.heading}
      subheading={problem.subheading}
    />

    <img
      src="/images/home/problem.png"
      alt="A farmer standing alone in a paddy field, looking worried at struggling crops surrounded by storm clouds, a pest, and a generic SMS notification — illustrating the disconnected, uncertain reality of farming today."
      loading="lazy"
      class="mx-auto mt-14 block w-full max-w-4xl rounded-3xl"
    />

    <div class="mt-12 grid gap-4 md:grid-cols-2">
      {problem.items.map((item) => (
        <article
          class="flex gap-5 rounded-3xl border border-ink-900/8 bg-white p-7 md:p-8"
        >
          <span class="font-display text-3xl font-medium text-forest-700/35 leading-none">
            {item.id}
          </span>
          <div>
            <h3 class="text-lg md:text-xl font-medium text-ink-900">
              {item.title}
            </h3>
            <p class="mt-2 text-base leading-relaxed text-ink-500">
              {item.description}
            </p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
