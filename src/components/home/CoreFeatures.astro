---
import { home } from "@/content/home";
import SectionHeading from "@/components/SectionHeading.astro";
import Icon from "@/components/Icon.astro";

const { features } = home;
---

<section id="features" class="bg-cream-25 py-24 md:py-32">
  <div class="container-page">
    <SectionHeading
      eyebrow={features.eyebrow}
      heading={features.heading}
      subheading={features.subheading}
    />

    <div class="mt-16 grid gap-5 md:grid-cols-2">
      {features.items.map((feature) => (
        <article
          class="group flex flex-col gap-5 rounded-3xl border border-ink-900/8 bg-white p-7 md:p-9 transition-all duration-300 hover:-translate-y-1 hover:border-forest-500/30 hover:shadow-[0_18px_50px_-25px_rgba(15,58,46,0.35)]"
        >
          <div class="flex items-center gap-4">
            <div class="grid size-12 place-items-center rounded-2xl bg-forest-900/[0.04] text-forest-700 ring-1 ring-forest-900/8">
              <Icon name={feature.iconKey} class="size-6" />
            </div>
            <h3 class="text-lg md:text-xl font-medium text-ink-900">
              {feature.title}
            </h3>
          </div>
          <p class="text-base leading-relaxed text-ink-500">
            {feature.description}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>
