---
import { home } from "@/content/home";
import SectionHeading from "@/components/SectionHeading.astro";
import Icon from "@/components/Icon.astro";

const { userRoles } = home;
---

<section id="roles" class="bg-cream-50 py-24 md:py-32">
  <div class="container-page">
    <SectionHeading
      eyebrow={userRoles.eyebrow}
      heading={userRoles.heading}
      subheading={userRoles.subheading}
    />

    <div class="mt-16 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {userRoles.items.map((role) => (
        <article
          class="group flex flex-col gap-5 rounded-3xl border border-ink-900/8 bg-white p-7 transition-all duration-300 hover:-translate-y-1 hover:border-forest-500/30 hover:shadow-[0_18px_50px_-25px_rgba(15,58,46,0.35)]"
        >
          <div class="grid size-14 place-items-center rounded-2xl bg-lime-400/20 text-forest-700 ring-1 ring-lime-400/40">
            <Icon name={role.iconKey} class="size-7" />
          </div>
          <div>
            <h3 class="text-lg font-medium text-ink-900">{role.title}</h3>
            <p class="mt-2 text-sm md:text-base leading-relaxed text-ink-500">
              {role.description}
            </p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
