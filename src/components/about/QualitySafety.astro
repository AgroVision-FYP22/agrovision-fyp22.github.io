---
import { about } from "@/content/about";
import SectionHeading from "@/components/SectionHeading.astro";
import Icon from "@/components/Icon.astro";

const { trust } = about;
---

<section id="quality" class="bg-forest-900 py-24 md:py-32 text-cream-50">
  <div class="container-page">
    <SectionHeading
      eyebrow={trust.eyebrow}
      heading={trust.heading}
      tone="light"
      size="compact"
    />

    <div class="mt-14 grid gap-4 md:grid-cols-2">
      {trust.pillars.map((pillar) => (
        <article
          class="flex flex-col gap-4 rounded-3xl border border-cream-50/10 bg-forest-800/40 p-7 md:p-8"
        >
          <div class="grid size-11 place-items-center rounded-xl bg-lime-400/15 text-lime-400 ring-1 ring-lime-400/30">
            <Icon name={pillar.iconKey} class="size-5" />
          </div>
          <h3 class="text-lg md:text-xl font-medium text-cream-50">
            {pillar.title}
          </h3>
          <p class="text-sm md:text-base leading-relaxed text-cream-100/75">
            {pillar.description}
          </p>
          <ul class="mt-1 space-y-2.5 border-t border-cream-50/10 pt-4">
            {pillar.points.map((point) => (
              <li class="flex items-start gap-3 text-sm leading-relaxed text-cream-100/70">
                <span class="mt-1.5 size-1.5 shrink-0 rounded-full bg-lime-400" aria-hidden="true"></span>
                <span>{point}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>
