---
import type { Paper } from "@/content/references";

interface Props {
  item: Paper;
}

const { item } = Astro.props;

const authorVenue = [item.authors, item.venue].filter(Boolean).join(" · ");
---

<details
  class="group paper-card overflow-hidden rounded-2xl border border-ink-900/8 border-l-4 border-l-lime-400 bg-white transition-colors hover:border-lime-500"
>
  <summary
    class="flex cursor-pointer list-none items-start justify-between gap-4 px-6 py-5 [&::-webkit-details-marker]:hidden"
  >
    <div class="min-w-0 flex-1">
      <h3 class="font-display text-base md:text-lg font-medium leading-snug text-ink-900">
        {item.title}
      </h3>
    </div>

    <div class="flex shrink-0 items-center gap-2.5">
      {item.year && (
        <span class="rounded-full bg-cream-50 px-2.5 py-1 text-[0.7rem] font-semibold uppercase tracking-[0.12em] text-ink-500">
          {item.year}
        </span>
      )}
      <svg
        class="chevron size-5 shrink-0 text-ink-500 transition-transform duration-200"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </div>
  </summary>

  <div class="border-t border-ink-900/8 px-6 py-6 md:px-6 md:py-7">
    {authorVenue && (
      <p class="mb-5 text-xs italic text-ink-500">
        {authorVenue}
      </p>
    )}

    <div class="space-y-5">
      <div>
        <span class="text-xs font-semibold uppercase tracking-[0.16em] text-forest-600">
          Summary
        </span>
        <p class="mt-2 text-sm md:text-base leading-relaxed text-ink-700">
          {item.description}
        </p>
      </div>

      {item.quote && (
        <blockquote class="rounded-xl border-l-2 border-lime-400 bg-cream-50 px-5 py-4 text-sm md:text-base italic leading-relaxed text-ink-700">
          &ldquo;{item.quote}&rdquo;
        </blockquote>
      )}

      <div>
        <span class="text-xs font-semibold uppercase tracking-[0.16em] text-forest-600">
          Relevance to AgroVision
        </span>
        <p class="mt-2 text-sm md:text-base leading-relaxed text-ink-700">
          {item.relevance}
        </p>
      </div>
    </div>

    <a
      href={item.link}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-6 inline-flex items-center gap-2 rounded-full bg-lime-400 px-5 py-2.5 text-sm font-semibold text-forest-900 transition-colors hover:bg-lime-300"
    >
      View paper
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="size-4"
        aria-hidden="true"
      >
        <path d="M7 17L17 7"></path>
        <path d="M8 7h9v9"></path>
      </svg>
    </a>
  </div>
</details>

<style>
  details.paper-card[open] .chevron {
    transform: rotate(180deg);
  }
</style>
