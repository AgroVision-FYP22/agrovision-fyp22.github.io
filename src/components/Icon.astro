---
import type { FeatureIconKey, RoleIconKey } from "@/content/home";
import type {
  AgentIconKey,
  TrustIconKey,
  AccessIconKey,
} from "@/content/about";

type IconKey =
  | FeatureIconKey
  | RoleIconKey
  | AgentIconKey
  | TrustIconKey
  | AccessIconKey
  | "network";

interface Props {
  name: IconKey;
  class?: string;
}

const { name, class: className = "size-6" } = Astro.props;

const baseAttrs = {
  viewBox: "0 0 24 24",
  fill: "none",
  stroke: "currentColor",
  "stroke-width": "1.7",
  "stroke-linecap": "round" as const,
  "stroke-linejoin": "round" as const,
  "aria-hidden": true,
};
---

{name === "assistant" && (
  <svg {...baseAttrs} class={className}>
    <path d="M12 3v2" />
    <rect x="4" y="5" width="16" height="13" rx="3" />
    <path d="M9 11h.01M15 11h.01" />
    <path d="M9 15c1 .8 2 1 3 1s2-.2 3-1" />
    <path d="M8 18l-2 3M16 18l2 3" />
  </svg>
)}

{name === "calculator" && (
  <svg {...baseAttrs} class={className}>
    <rect x="4" y="3" width="16" height="18" rx="2.5" />
    <path d="M8 7h8" />
    <path d="M8 12h.01M12 12h.01M16 12h.01" />
    <path d="M8 16h.01M12 16h.01M16 16h.01" />
  </svg>
)}

{name === "map" && (
  <svg {...baseAttrs} class={className}>
    <path d="M3 6v15l6-3 6 3 6-3V3l-6 3-6-3-6 3z" />
    <path d="M9 3v15" />
    <path d="M15 6v15" />
  </svg>
)}

{name === "users" && (
  <svg {...baseAttrs} class={className}>
    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
    <circle cx="9" cy="7" r="4" />
    <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
    <path d="M16 3.13a4 4 0 0 1 0 7.75" />
  </svg>
)}

{name === "farmer" && (
  <svg {...baseAttrs} class={className}>
    <path d="M12 2c-3 3-3 7 0 10" />
    <path d="M12 12c-4-1-7-4-7-8 4 0 7 3 7 8z" />
    <path d="M12 12c4-1 7-4 7-8-4 0-7 3-7 8z" />
    <path d="M12 12v10" />
  </svg>
)}

{name === "agronomist" && (
  <svg {...baseAttrs} class={className}>
    <path d="M2 9l10-5 10 5-10 5L2 9z" />
    <path d="M6 11v4c0 1.5 3 3 6 3s6-1.5 6-3v-4" />
    <path d="M22 9v5" />
  </svg>
)}

{name === "officer" && (
  <svg {...baseAttrs} class={className}>
    <path d="M12 2l8 3v6c0 5-3.5 9-8 11-4.5-2-8-6-8-11V5l8-3z" />
    <path d="M9 12l2 2 4-4" />
  </svg>
)}

{name === "researcher" && (
  <svg {...baseAttrs} class={className}>
    <path d="M9 3h6" />
    <path d="M10 3v6L4.5 19a2 2 0 0 0 1.7 3h11.6a2 2 0 0 0 1.7-3L14 9V3" />
    <path d="M7.5 14h9" />
  </svg>
)}

{name === "disease" && (
  <svg {...baseAttrs} class={className}>
    <path d="M12 21c5-3 8-7 8-12V4l-3 1c-3 1-5 3-5 6v10z" />
    <path d="M12 21c-5-3-8-7-8-12V4l3 1c3 1 5 3 5 6v10z" />
    <circle cx="9" cy="11" r="1.2" fill="currentColor" />
    <circle cx="14" cy="14" r="1.2" fill="currentColor" />
  </svg>
)}

{name === "soil" && (
  <svg {...baseAttrs} class={className}>
    <path d="M3 8l9-4 9 4-9 4-9-4z" />
    <path d="M3 13l9 4 9-4" />
    <path d="M3 17l9 4 9-4" />
  </svg>
)}

{name === "weather" && (
  <svg {...baseAttrs} class={className}>
    <circle cx="7" cy="9" r="3" />
    <path d="M11 17h7a3 3 0 0 0 0-6 5 5 0 0 0-9.7-1" />
    <path d="M8 21l1-2M13 21l1-2M18 21l1-2" />
  </svg>
)}

{name === "orchestrator" && (
  <svg {...baseAttrs} class={className}>
    <circle cx="12" cy="6" r="2.2" />
    <circle cx="5" cy="18" r="2.2" />
    <circle cx="19" cy="18" r="2.2" />
    <circle cx="12" cy="14" r="2.2" />
    <path d="M12 8.2v3.6" />
    <path d="M10.3 15.4l-3.6 1.5" />
    <path d="M13.7 15.4l3.6 1.5" />
  </svg>
)}

{name === "judge" && (
  <svg {...baseAttrs} class={className}>
    <path d="M12 2l8 3v6c0 5-3.5 9-8 11-4.5-2-8-6-8-11V5l8-3z" />
    <path d="M9 12l2 2 4-4" />
  </svg>
)}

{name === "grounding" && (
  <svg {...baseAttrs} class={className}>
    <circle cx="12" cy="6" r="3" />
    <path d="M12 9v13" />
    <path d="M6 16a6 6 0 0 0 12 0" />
    <path d="M3 22h18" />
  </svg>
)}

{name === "metrics" && (
  <svg {...baseAttrs} class={className}>
    <path d="M3 21h18" />
    <rect x="5" y="13" width="3" height="8" />
    <rect x="10.5" y="9" width="3" height="12" />
    <rect x="16" y="5" width="3" height="16" />
  </svg>
)}

{name === "observability" && (
  <svg {...baseAttrs} class={className}>
    <path d="M3 12h3l3-8 4 16 3-10 2 6h3" />
  </svg>
)}

{name === "voice" && (
  <svg {...baseAttrs} class={className}>
    <rect x="9" y="3" width="6" height="12" rx="3" />
    <path d="M5 11a7 7 0 0 0 14 0" />
    <path d="M12 18v3" />
    <path d="M8 21h8" />
  </svg>
)}

{name === "lock" && (
  <svg {...baseAttrs} class={className}>
    <rect x="4" y="11" width="16" height="10" rx="2" />
    <path d="M8 11V7a4 4 0 0 1 8 0v4" />
    <circle cx="12" cy="16" r="1.2" fill="currentColor" />
  </svg>
)}

{name === "network" && (
  <svg {...baseAttrs} class={className}>
    <circle cx="12" cy="5" r="2" />
    <circle cx="5" cy="19" r="2" />
    <circle cx="19" cy="19" r="2" />
    <circle cx="12" cy="12" r="2" />
    <path d="M12 7v3" />
    <path d="M10.5 13.5l-4 4" />
    <path d="M13.5 13.5l4 4" />
  </svg>
)}

{name === "pest" && (
  <svg {...baseAttrs} class={className}>
    <ellipse cx="12" cy="13" rx="5" ry="6" />
    <path d="M12 7V5" />
    <path d="M10 5L8 3M14 5l2-2" />
    <path d="M7 11l-3-1M17 11l3-1" />
    <path d="M7 14H4M17 14h3" />
    <path d="M8 17l-3 2M16 17l3 2" />
  </svg>
)}

{name === "price" && (
  <svg {...baseAttrs} class={className}>
    <circle cx="12" cy="12" r="9" />
    <path d="M14.5 9h-3a2 2 0 0 0 0 4h2a2 2 0 0 1 0 4h-3.5" />
    <path d="M12 6.5V9M12 17v2.5" />
  </svg>
)}

{name === "planting" && (
  <svg {...baseAttrs} class={className}>
    <path d="M12 22V11" />
    <path d="M12 11C8 10 7 7 7 4c3 0 5 2 5 7z" />
    <path d="M12 11c4-1 5-4 5-7-3 0-5 2-5 7z" />
    <path d="M5 19h14" />
  </svg>
)}
