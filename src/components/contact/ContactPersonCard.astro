---
import type { ContactPerson } from '@/content/contact';

interface Props {
  person: ContactPerson;
}

const {
  person
} = Astro.props;

---
<div
  class="grid gap-5 rounded-3xl border border-ink-900/8 bg-white p-7 md:grid-cols-5 md:items-stretch md:p-8"
>
  <div class="overflow-hidden rounded-2xl md:col-span-2 md:self-stretch">
    {person.image ? (
      <img
        src={person.image}
        alt={person.name}
        class="h-full w-full object-cover object-center"
      />
    ) : (
      <div class="flex min-h-44 h-full items-center justify-center bg-forest-50 text-center font-display text-2xl text-forest-700/35">
        {person.name}
      </div>
    )}
  </div>
  <div class="md:col-span-3 md:flex md:flex-col md:justify-center">
    <div class="space-y-3 text-ink-900">
      <div class="text-lg font-semibold md:text-xl">
        {person.name}
      </div>
      <div class="text-base font-normal text-ink-600 md:text-lg">
        {person.designation}
      </div>
      <div class="break-all text-base font-normal text-ink-600 md:text-lg">
        {person.email ? (
          <a
            href={`mailto:${person.email}`}
            class="transition-colors hover:text-forest-700"
          >
            {person.email}
          </a>
        ) : null}
      </div>
    </div>
  </div>
</div>