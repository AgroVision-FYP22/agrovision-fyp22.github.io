---
import { contact } from "@/content/contact";
import SectionHeading from "@/components/SectionHeading.astro";

const { department } = contact;

const rows = [
  { label: "Faculty", value: department.faculty },
  { label: "Department", value: department.department },
  { label: "Address", value: department.address },
];
---

<section id="department" class="bg-cream-50 py-20 md:py-24">
  <div class="container-page">
    <SectionHeading
      eyebrow="Department"
      heading="Where the project is based"
      size="compact"
    />

    <article class="mt-10 rounded-3xl border border-ink-900/8 bg-white p-7 md:p-9">
      <span class="eyebrow text-forest-600">
        <span class="inline-block h-px w-6 bg-current opacity-60"></span>
        Institution
      </span>
      <h3 class="mt-4 font-display text-2xl md:text-3xl font-medium leading-tight text-ink-900">
        {department.name}
      </h3>

      <dl class="mt-6 space-y-4 border-t border-ink-900/8 pt-5">
        {rows.map((row) => (
          <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:gap-6">
            <dt class="shrink-0 text-xs font-semibold uppercase tracking-[0.16em] text-ink-500 sm:w-32">
              {row.label}
            </dt>
            <dd class="text-sm md:text-base leading-relaxed text-ink-700">
              {row.value}
            </dd>
          </div>
        ))}
      </dl>
    </article>
  </div>
</section>
