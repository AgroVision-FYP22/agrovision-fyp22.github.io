---
interface Props {
  eyebrow: string;
  heading: string;
  subheading?: string;
  align?: "left" | "center";
  tone?: "dark" | "light";
  size?: "display" | "compact";
}

const {
  eyebrow,
  heading,
  subheading,
  align = "left",
  tone = "dark",
  size = "display",
} = Astro.props;

const alignClass = align === "center" ? "items-center text-center" : "items-start text-left";
const headingColor = tone === "light" ? "text-cream-50" : "text-ink-900";
const subColor = tone === "light" ? "text-cream-100/80" : "text-ink-500";
const eyebrowColor = tone === "light" ? "text-lime-400" : "text-forest-600";
const headingSize =
  size === "compact"
    ? "text-2xl md:text-3xl leading-[1.2]"
    : "text-3xl md:text-4xl lg:text-5xl leading-[1.1]";
---

<div class={`flex flex-col ${alignClass} max-w-2xl ${align === "center" ? "mx-auto" : ""}`}>
  <span class={`eyebrow ${eyebrowColor}`}>
    <span class="inline-block h-px w-6 bg-current opacity-60"></span>
    {eyebrow}
  </span>
  {heading && (
    <h2 class={`mt-4 ${headingSize} ${headingColor}`}>
      {heading}
    </h2>
  )}
  {subheading && (
    <p class={`mt-5 text-base md:text-lg leading-relaxed ${subColor}`}>
      {subheading}
    </p>
  )}
</div>
