---
import { site } from "@/content/site";
---

<footer class="bg-forest-900 text-cream-50">
  <div class="container-page py-16 md:py-20">
    <div class="grid gap-12 md:grid-cols-[1.5fr_1fr_1fr]">
      <div>
        <a href="/" class="flex items-center gap-2.5 font-display text-2xl">
          <span class="grid size-9 place-items-center rounded-full bg-lime-400 text-forest-900">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="size-4.5">
              <path d="M12 2c-1.5 4 1.5 6.5 4 7-1 3.5-4.5 5-7 4.5C6 17 4 19 4 22"/>
              <path d="M12 2c1.5 4-1.5 6.5-4 7 1 3.5 4.5 5 7 4.5"/>
            </svg>
          </span>
          {site.brand}
        </a>
        <p class="mt-5 max-w-sm text-sm leading-relaxed text-cream-100/70">
          {site.footer.blurb}
        </p>
      </div>

      {site.footer.columns.map((col) => (
        <div>
          <h4 class="text-xs font-semibold uppercase tracking-[0.18em] text-lime-400">
            {col.heading}
          </h4>
          <ul class="mt-5 space-y-3">
            {col.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-cream-50/85 transition-colors hover:text-lime-400"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-16 flex flex-col-reverse gap-4 border-t border-cream-50/10 pt-6 md:flex-row md:items-center md:justify-between">
      <p class="text-xs text-cream-50/60">{site.footer.copyright}</p>
      <p class="text-xs text-cream-50/60">{site.tagline}</p>
    </div>
  </div>
</footer>
