---
import "@fontsource-variable/inter";
import "@fontsource-variable/fraunces";
import "@/styles/global.css";
import { site } from "@/content/site";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = site.brand,
  description = site.description,
} = Astro.props;

const fullTitle = title === site.brand ? `${site.brand} — ${site.tagline}` : `${title} · ${site.brand}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/images/og-image.jpg" />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body class="min-h-screen antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-50 focus:rounded-full focus:bg-forest-900 focus:px-4 focus:py-2 focus:text-sm focus:text-white"
    >
      Skip to content
    </a>

    <Navbar />

    <main id="main">
      <slot />
    </main>

    <Footer />
  </body>
</html>
